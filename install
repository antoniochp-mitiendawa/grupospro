#!/data/data/com.termux/files/usr/bin/bash

# =========================================================
# PROYECTO: grupospro
# FUNCIÓN: Instalador Maestro de Entorno (Bloque 1)
# =========================================================

# Colores
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

clear
echo -e "${BLUE}=========================================${NC}"
echo -e "${YELLOW}       INSTALADOR GRUPOSPRO V1.0        ${NC}"
echo -e "${BLUE}=========================================${NC}"

# 1. REPARACIÓN Y ACTUALIZACIÓN (Evita errores de SSL/CURL)
echo -e "\n${BLUE}[ 1/6 ]${NC} Reparando librerías y actualizando..."
# Forzamos actualización desatendida para evitar preguntas técnicas al cliente
pkg update -y
pkg upgrade -y -o Dpkg::Options::="--force-confold"
pkg install -y openssl libcurl curl ca-certificates
echo -e "${GREEN}[ OK ]${NC} Sistema base reparado y al día."

# 2. HERRAMIENTAS DE COMPILACIÓN
echo -e "${BLUE}[ 2/6 ]${NC} Instalando herramientas de compilación..."
pkg install -y binutils python clang make build-essential
echo -e "${GREEN}[ OK ]${NC} Compilación lista."

# 3. MOTORES
echo -e "${BLUE}[ 3/6 ]${NC} Instalando Node.js y Git..."
pkg install -y nodejs git
echo -e "${GREEN}[ OK ]${NC} Motores instalados."

# 4. MULTIMEDIA Y DATOS
echo -e "${BLUE}[ 4/6 ]${NC} Instalando SQLite3, FFmpeg y Libwebp..."
pkg install -y ffmpeg libwebp sqlite
echo -e "${GREEN}[ OK ]${NC} Soporte multimedia listo."

# 5. GESTOR DE PROCESOS (PM2)
echo -e "${BLUE}[ 5/6 ]${NC} Configurando PM2..."
npm install -g pm2
echo -e "${GREEN}[ OK ]${NC} PM2 instalado globalmente."

# 6. ESTRUCTURA
echo -e "${BLUE}[ 6/6 ]${NC} Configurando directorio 'grupospro'..."
mkdir -p $HOME/grupospro
echo -e "${GREEN}[ OK ]${NC} Directorio listo."

# PERMISOS Y CIERRE
echo -e "\n${YELLOW}[ IMPORTANTE ]${NC} Acepta el permiso de almacenamiento."
termux-setup-storage

# REPORTE FINAL
NODE_V=$(node -v)
PM2_V=$(pm2 -v | tail -n 1)
SQL_V=$(sqlite3 --version | cut -d ' ' -f 1)

echo -e "\n${BLUE}=========================================${NC}"
echo -e "${GREEN}      INSTALACIÓN COMPLETADA EXITOSAMENTE${NC}"
echo -e "${BLUE}=========================================${NC}"
echo -e "🟢 Node.js:   ${GREEN}$NODE_V${NC}"
echo -e "🟢 PM2:       ${GREEN}v$PM2_V${NC}"
echo -e "🟢 SQLite:    ${GREEN}v$SQL_V${NC}"
echo -e "🛠️ Compilación: ${GREEN}[ LISTA ]${NC}"
echo -e "${BLUE}=========================================${NC}"
